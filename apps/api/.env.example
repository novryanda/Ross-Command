PORT=3001
NODE_ENV=production

# PostgreSQL eksternal (Dokploy / managed instance)
DATABASE_URL=postgresql://user:password@postgres-host:5432/komando_center

# Auth (Better Auth)
BETTER_AUTH_SECRET=replace-with-at-least-32-characters-secret
BETTER_AUTH_URL=https://api.your-domain.com
BETTER_AUTH_TRUSTED_ORIGINS=https://your-domain.com,https://api.your-domain.com
BETTER_AUTH_TRUST_PROXY_HEADERS=true

# Email / SMTP
INTERNAL_EMAIL_DOMAIN=komando.local
EMAIL_PROVIDER=smtp
EMAIL_FROM="Command Center <no-reply@example.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=replace-with-app-password

# Startup
RUN_MIGRATE_ON_STARTUP=true

# System settings encryption (32 bytes / 64 hex chars)
SETTINGS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# URL publik untuk webhook Apify (sama dengan URL tunnel/domain yang bisa diakses eksternal)
API_PUBLIC_BASE_URL=https://your-domain.com
