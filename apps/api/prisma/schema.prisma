generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SocialPlatform {
  instagram
  twitter_x
  facebook
  tiktok
  youtube
  other
}

enum OrderType {
  posting
  engagement
  komentar
  report_akun
}

enum OrderSentiment {
  positive
  negative
}

enum OrderStatus {
  draft
  aktif
  selesai
  expired
  dibatalkan
}

enum OrderTargetType {
  unit
  individual
}

enum AssignmentStatus {
  belum_dikerjakan
  selesai
  terlambat
}

model User {
  id                  String           @id @default(uuid()) @db.Uuid
  fullName            String           @map("full_name") @db.VarChar(150)
  email               String           @unique @db.VarChar(255)
  emailVerified       Boolean          @default(true) @map("email_verified")
  username            String           @unique @db.VarChar(50)
  displayUsername     String?          @map("display_username") @db.VarChar(150)
  image               String?          @db.Text
  role                String           @default("member") @db.VarChar(50)
  banned              Boolean          @default(false)
  banReason           String?          @map("ban_reason") @db.Text
  banExpires          DateTime?        @map("ban_expires")
  nip                 String?          @unique @db.VarChar(50)
  failedLoginAttempts Int              @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?        @map("locked_until")
  lastLoginAt         DateTime?        @map("last_login_at")
  deletedAt           DateTime?        @map("deleted_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  sessions            Session[]
  accounts            Account[]
  commandedUnits      Unit[]           @relation("commanded_units")
  unitMemberships     UnitMember[]
  socialAccounts      SocialAccount[]
  createdOrders       Order[]          @relation("created_orders")
  directTargets       OrderTarget[]    @relation("direct_target_users")
  taskAssignments     TaskAssignment[]
  submissions         Submission[]
  loginAttempts       LoginAttempt[]

  @@index([deletedAt])
  @@index([role])
  @@map("users")
}

model Session {
  id             String   @id @default(uuid()) @db.Uuid
  expiresAt      DateTime @map("expires_at")
  token          String   @unique @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  userAgent      String?  @map("user_agent") @db.Text
  userId         String   @map("user_id") @db.Uuid
  impersonatedBy String?  @map("impersonated_by") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String    @map("account_id") @db.Text
  providerId            String    @map("provider_id") @db.Text
  userId                String    @map("user_id") @db.Uuid
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?   @db.Text
  idToken               String?   @map("id_token") @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

model RateLimit {
  id          String @id @default(uuid()) @db.Uuid
  key         String @unique @db.Text
  count       Int
  lastRequest BigInt @map("last_request")

  @@map("rate_limit")
}

model Unit {
  id           String        @id @default(uuid()) @db.Uuid
  parentId     String?       @map("parent_id") @db.Uuid
  name         String        @db.VarChar(150)
  description  String?       @db.Text
  commanderId  String?       @map("commander_id") @db.Uuid
  depthLevel   Int           @default(0) @map("depth_level")
  path         String        @db.VarChar(1000)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")
  parent       Unit?         @relation("unit_tree", fields: [parentId], references: [id])
  children     Unit[]        @relation("unit_tree")
  commander    User?         @relation("commanded_units", fields: [commanderId], references: [id])
  memberships  UnitMember[]
  orderTargets OrderTarget[]

  @@unique([parentId, name])
  @@index([parentId])
  @@index([commanderId])
  @@index([path])
  @@index([deletedAt])
  @@map("units")
}

model UnitMember {
  id        String    @id @default(uuid()) @db.Uuid
  unitId    String    @map("unit_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  joinedAt  DateTime  @default(now()) @map("joined_at")
  removedAt DateTime? @map("removed_at")
  unit      Unit      @relation(fields: [unitId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([unitId])
  @@index([userId])
  @@index([removedAt])
  @@map("unit_members")
}

model SocialAccount {
  id         String         @id @default(uuid()) @db.Uuid
  userId     String         @map("user_id") @db.Uuid
  platform   SocialPlatform
  username   String         @db.VarChar(150)
  profileUrl String?        @map("profile_url") @db.Text
  notes      String?        @db.Text
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  deletedAt  DateTime?      @map("deleted_at")
  user       User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([platform])
  @@index([deletedAt])
  @@map("social_accounts")
}

model Order {
  id                String           @id @default(uuid()) @db.Uuid
  createdById       String           @map("created_by") @db.Uuid
  title             String           @db.VarChar(255)
  orderType         OrderType        @map("order_type")
  description       String           @db.Text
  narration         String?          @db.Text
  sentiment         OrderSentiment?
  engagementActions Json?            @map("engagement_actions")
  reportReason      String?          @map("report_reason") @db.Text
  status            OrderStatus      @default(draft)
  deadline          DateTime
  sentAt            DateTime?        @map("sent_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")
  createdBy         User             @relation("created_orders", fields: [createdById], references: [id])
  targets           OrderTarget[]
  socialTargets     OrderSocialTarget[]
  assignments       TaskAssignment[]

  @@index([createdById])
  @@index([status])
  @@index([deadline])
  @@index([deletedAt])
  @@map("orders")
}

model OrderSocialTarget {
  id        String         @id @default(uuid()) @db.Uuid
  orderId   String         @map("order_id") @db.Uuid
  platform  SocialPlatform
  url       String         @db.Text
  sortOrder Int            @default(0) @map("sort_order")
  createdAt DateTime       @default(now()) @map("created_at")
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_social_targets")
}

model OrderTarget {
  id                  String          @id @default(uuid()) @db.Uuid
  orderId             String          @map("order_id") @db.Uuid
  unitId              String?         @map("unit_id") @db.Uuid
  userId              String?         @map("user_id") @db.Uuid
  targetType          OrderTargetType @map("target_type")
  resolvedMemberCount Int?            @map("resolved_member_count")
  createdAt           DateTime        @default(now()) @map("created_at")
  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  unit                Unit?           @relation(fields: [unitId], references: [id])
  user                User?           @relation("direct_target_users", fields: [userId], references: [id])

  @@unique([orderId, unitId])
  @@unique([orderId, userId])
  @@index([orderId])
  @@index([unitId])
  @@index([userId])
  @@map("order_targets")
}

model TaskAssignment {
  id          String           @id @default(uuid()) @db.Uuid
  orderId     String           @map("order_id") @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  status      AssignmentStatus @default(belum_dikerjakan)
  assignedAt  DateTime         @default(now()) @map("assigned_at")
  completedAt DateTime?        @map("completed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  order       Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id])
  submissions Submission[]

  @@unique([orderId, userId])
  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("task_assignments")
}

model Submission {
  id           String         @id @default(uuid()) @db.Uuid
  assignmentId String         @map("assignment_id") @db.Uuid
  userId       String         @map("user_id") @db.Uuid
  driveLink    String         @map("drive_link") @db.Text
  notes        String?        @db.Text
  isLatest     Boolean        @default(true) @map("is_latest")
  submittedAt  DateTime       @default(now()) @map("submitted_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  assignment   TaskAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id])

  @@index([assignmentId])
  @@index([userId])
  @@index([assignmentId, isLatest])
  @@map("submissions")
}

model LoginAttempt {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  ipAddress   String   @map("ip_address") @db.VarChar(45)
  isSuccess   Boolean  @map("is_success")
  attemptedAt DateTime @default(now()) @map("attempted_at")
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([attemptedAt])
  @@map("login_attempts")
}
