generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SocialPlatform {
  instagram
  twitter_x
  facebook
  tiktok
  youtube
  other
}

enum OrderType {
  posting
  engagement
  counter
  report_akun
}

enum OrderStatus {
  draft
  aktif
  selesai
  expired
  dibatalkan
}

enum OrderTargetType {
  unit
  individual
}

enum OrderTargetAudience {
  all_members
  unit_leaders
  direct_user
}

enum AssignmentStatus {
  belum_dikerjakan
  selesai
  terlambat
}

enum ActivityLogType {
  order_created
  order_sent
  submission_sent
}

enum MetricScrapePhase {
  baseline
  deadline
}

enum MetricScrapeStatus {
  pending
  running
  succeeded
  failed
}

enum Gender {
  pria
  wanita
}

enum EmploymentType {
  tni
  pns
  p3k
}

enum Religion {
  islam
  kristen_protestan
  katolik
  hindu
  buddha
  konghucu
}

model User {
  id                     String           @id @default(uuid()) @db.Uuid
  fullName               String           @map("full_name") @db.VarChar(150)
  email                  String           @unique @db.VarChar(255)
  emailVerified          Boolean          @default(true) @map("email_verified")
  username               String           @unique @db.VarChar(50)
  displayUsername        String?          @map("display_username") @db.VarChar(150)
  image                  String?          @db.Text
  role                   String           @default("member") @db.VarChar(50)
  banned                 Boolean          @default(false)
  banReason              String?          @map("ban_reason") @db.Text
  banExpires             DateTime?        @map("ban_expires")
  identityNumber         String?          @unique @map("identity_number") @db.VarChar(50)
  gender                 Gender?
  employmentType         EmploymentType?  @map("employment_type")
  rank                   String?          @db.VarChar(50)
  grade                  String?          @db.VarChar(50)
  religion               Religion?
  phoneNumber            String?          @map("phone_number") @db.VarChar(30)
  failedLoginAttempts    Int              @default(0) @map("failed_login_attempts")
  lockedUntil            DateTime?        @map("locked_until")
  lastLoginAt            DateTime?        @map("last_login_at")
  deletedAt              DateTime?        @map("deleted_at")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")
  sessions               Session[]
  accounts               Account[]
  commandedUnits         Unit[]           @relation("commanded_units")
  unitMemberships        UnitMember[]
  socialAccounts         SocialAccount[]
  createdOrders          Order[]          @relation("created_orders")
  directTargets          OrderTarget[]    @relation("direct_target_users")
  taskAssignments        TaskAssignment[]
  submissions            Submission[]
  representedSubmissions Submission[]     @relation("submitted_by_user")
  loginAttempts          LoginAttempt[]
  activityLogs           ActivityLog[]    @relation("activity_actor")
  updatedSystemSettings  SystemSetting[]  @relation("system_settings_updated_by")

  @@index([deletedAt])
  @@index([role])
  @@map("users")
}

model Session {
  id             String   @id @default(uuid()) @db.Uuid
  expiresAt      DateTime @map("expires_at")
  token          String   @unique @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  userAgent      String?  @map("user_agent") @db.Text
  userId         String   @map("user_id") @db.Uuid
  impersonatedBy String?  @map("impersonated_by") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String    @map("account_id") @db.Text
  providerId            String    @map("provider_id") @db.Text
  userId                String    @map("user_id") @db.Uuid
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?   @db.Text
  idToken               String?   @map("id_token") @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

model RateLimit {
  id          String @id @default(uuid()) @db.Uuid
  key         String @unique @db.Text
  count       Int
  lastRequest BigInt @map("last_request")

  @@map("rate_limit")
}

model Unit {
  id                    String        @id @default(uuid()) @db.Uuid
  parentId              String?       @map("parent_id") @db.Uuid
  name                  String        @db.VarChar(150)
  description           String?       @db.Text
  commanderId           String?       @map("commander_id") @db.Uuid
  leaderOnlyAssignments Boolean       @default(false) @map("leader_only_assignments")
  depthLevel            Int           @default(0) @map("depth_level")
  path                  String        @db.VarChar(1000)
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  deletedAt             DateTime?     @map("deleted_at")
  parent                Unit?         @relation("unit_tree", fields: [parentId], references: [id])
  children              Unit[]        @relation("unit_tree")
  commander             User?         @relation("commanded_units", fields: [commanderId], references: [id])
  memberships           UnitMember[]
  orderTargets          OrderTarget[]

  @@unique([parentId, name])
  @@index([parentId])
  @@index([commanderId])
  @@index([path])
  @@index([deletedAt])
  @@map("units")
}

model UnitMember {
  id        String    @id @default(uuid()) @db.Uuid
  unitId    String    @map("unit_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  joinedAt  DateTime  @default(now()) @map("joined_at")
  removedAt DateTime? @map("removed_at")
  unit      Unit      @relation(fields: [unitId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([unitId])
  @@index([userId])
  @@index([removedAt])
  @@map("unit_members")
}

model SocialAccount {
  id         String         @id @default(uuid()) @db.Uuid
  userId     String         @map("user_id") @db.Uuid
  platform   SocialPlatform
  username   String         @db.VarChar(150)
  profileUrl String?        @map("profile_url") @db.Text
  notes      String?        @db.Text
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  deletedAt  DateTime?      @map("deleted_at")
  user       User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([platform])
  @@index([deletedAt])
  @@map("social_accounts")
}

model Order {
  id                     String              @id @default(uuid()) @db.Uuid
  createdById            String              @map("created_by") @db.Uuid
  title                  String              @db.VarChar(255)
  orderType              OrderType           @map("order_type")
  description            String              @db.Text
  narration              String?             @db.Text
  engagementActions      Json?               @map("engagement_actions")
  reportReason           String?             @map("report_reason") @db.Text
  postingSourceUrl       String?             @map("posting_source_url") @db.Text
  postingTargetPlatforms Json?               @map("posting_target_platforms")
  status                 OrderStatus         @default(draft)
  deadline               DateTime
  sentAt                 DateTime?           @map("sent_at")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  deletedAt              DateTime?           @map("deleted_at")
  createdBy              User                @relation("created_orders", fields: [createdById], references: [id])
  targets                OrderTarget[]
  socialTargets          OrderSocialTarget[]
  assignments            TaskAssignment[]
  activityLogs           ActivityLog[]
  metricScrapeRuns       MetricScrapeRun[]

  @@index([createdById])
  @@index([status])
  @@index([deadline])
  @@index([deletedAt])
  @@map("orders")
}

model OrderSocialTarget {
  id                String              @id @default(uuid()) @db.Uuid
  orderId           String              @map("order_id") @db.Uuid
  platform          SocialPlatform
  url               String              @db.Text
  baselineMetrics   Json?               @map("baseline_metrics")
  finalMetrics      Json?               @map("final_metrics")
  baselineScrapedAt DateTime?           @map("baseline_scraped_at")
  finalScrapedAt    DateTime?           @map("final_scraped_at")
  sortOrder         Int                 @default(0) @map("sort_order")
  createdAt         DateTime            @default(now()) @map("created_at")
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  metricScrapeRuns  MetricScrapeRun[]

  @@index([orderId])
  @@map("order_social_targets")
}

model OrderTarget {
  id                  String              @id @default(uuid()) @db.Uuid
  orderId             String              @map("order_id") @db.Uuid
  unitId              String?             @map("unit_id") @db.Uuid
  userId              String?             @map("user_id") @db.Uuid
  targetType          OrderTargetType     @map("target_type")
  targetAudience      OrderTargetAudience @default(all_members) @map("target_audience")
  resolvedMemberCount Int?                @map("resolved_member_count")
  createdAt           DateTime            @default(now()) @map("created_at")
  order               Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  unit                Unit?               @relation(fields: [unitId], references: [id])
  user                User?               @relation("direct_target_users", fields: [userId], references: [id])

  @@unique([orderId, unitId, targetAudience])
  @@unique([orderId, userId])
  @@index([orderId])
  @@index([unitId])
  @@index([userId])
  @@map("order_targets")
}

model TaskAssignment {
  id           String           @id @default(uuid()) @db.Uuid
  orderId      String           @map("order_id") @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  status       AssignmentStatus @default(belum_dikerjakan)
  assignedAt   DateTime         @default(now()) @map("assigned_at")
  completedAt  DateTime?        @map("completed_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id])
  submissions  Submission[]
  activityLogs ActivityLog[]

  @@unique([orderId, userId])
  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("task_assignments")
}

model Submission {
  id                String         @id @default(uuid()) @db.Uuid
  assignmentId      String         @map("assignment_id") @db.Uuid
  userId            String         @map("user_id") @db.Uuid
  submittedByUserId String         @map("submitted_by_user_id") @db.Uuid
  submissionSource  String         @default("self") @map("submission_source") @db.VarChar(30)
  driveLink         String?        @map("drive_link") @db.Text
  platformLinks     Json?          @map("platform_links")
  targetMetrics     Json?          @map("target_metrics")
  views             Int            @default(0)
  likes             Int            @default(0)
  comments          Int            @default(0)
  shares            Int            @default(0)
  reposts           Int            @default(0)
  notes             String?        @db.Text
  isLatest          Boolean        @default(true) @map("is_latest")
  submittedAt       DateTime       @default(now()) @map("submitted_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  assignment        TaskAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user              User           @relation(fields: [userId], references: [id])
  submittedBy       User           @relation("submitted_by_user", fields: [submittedByUserId], references: [id])
  activityLogs      ActivityLog[]

  @@index([assignmentId])
  @@index([userId])
  @@index([submittedByUserId])
  @@index([assignmentId, isLatest])
  @@map("submissions")
}

model LoginAttempt {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  ipAddress   String   @map("ip_address") @db.VarChar(45)
  isSuccess   Boolean  @map("is_success")
  attemptedAt DateTime @default(now()) @map("attempted_at")
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([attemptedAt])
  @@map("login_attempts")
}

model ActivityLog {
  id           String          @id @default(uuid()) @db.Uuid
  activityKey  String          @unique @map("activity_key") @db.VarChar(200)
  type         ActivityLogType
  actorUserId  String?         @map("actor_user_id") @db.Uuid
  orderId      String?         @map("order_id") @db.Uuid
  assignmentId String?         @map("assignment_id") @db.Uuid
  submissionId String?         @map("submission_id") @db.Uuid
  createdAt    DateTime        @default(now()) @map("created_at")
  actorUser    User?           @relation("activity_actor", fields: [actorUserId], references: [id])
  order        Order?          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignment   TaskAssignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  submission   Submission?     @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([orderId])
  @@index([assignmentId])
  @@index([submissionId])
  @@index([createdAt])
  @@map("activity_logs")
}

model SystemSetting {
  id                    String   @id @default("default") @db.VarChar(50)
  apifyApiTokenEnc      String?  @map("apify_api_token_enc") @db.Text
  apifyWebhookSecretEnc String?  @map("apify_webhook_secret_enc") @db.Text
  apifyActors           Json?    @map("apify_actors")
  updatedById           String?  @map("updated_by_id") @db.Uuid
  updatedAt             DateTime @updatedAt @map("updated_at")
  updatedBy             User?    @relation("system_settings_updated_by", fields: [updatedById], references: [id])

  @@map("system_settings")
}

model MetricScrapeRun {
  id                  String             @id @default(uuid()) @db.Uuid
  orderId             String             @map("order_id") @db.Uuid
  orderSocialTargetId String             @map("order_social_target_id") @db.Uuid
  phase               MetricScrapePhase
  status              MetricScrapeStatus   @default(pending)
  apifyRunId          String?            @map("apify_run_id") @db.VarChar(100)
  apifyActorId        String?            @map("apify_actor_id") @db.VarChar(200)
  metrics             Json?
  rawPayload          Json?              @map("raw_payload")
  errorMessage        String?            @map("error_message") @db.Text
  startedAt           DateTime           @default(now()) @map("started_at")
  completedAt         DateTime?          @map("completed_at")
  order               Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderSocialTarget   OrderSocialTarget  @relation(fields: [orderSocialTargetId], references: [id], onDelete: Cascade)

  @@unique([orderSocialTargetId, phase])
  @@index([orderId])
  @@index([status])
  @@index([apifyRunId])
  @@map("metric_scrape_runs")
}
